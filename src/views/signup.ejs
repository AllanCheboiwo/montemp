<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create account — TimeLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
  <div class="shell">

    <div class="brand brand--signup">
      <div class="brand-grid"></div>
      <div class="brand-logo">Time<em>Log</em></div>
      <div class="brand-body">
        <div class="brand-eyebrow">Free to start</div>
        <h1 class="brand-headline">
          Your time tells<br>
          <span>a story.</span>
        </h1>
        <p class="brand-sub">
          Start understanding how you spend each day. Log it once, learn from it forever.
        </p>
        <div class="brand-stats">
          <div class="stat-block">
            <div class="stat-number">10<em>k</em></div>
            <div class="stat-label">People tracking time</div>
          </div>
          <div class="stat-block">
            <div class="stat-number">4<em>M</em></div>
            <div class="stat-label">Hours logged</div>
          </div>
          <div class="stat-block">
            <div class="stat-number"><em>∞</em></div>
            <div class="stat-label">Free forever plan</div>
          </div>
          <div class="stat-block">
            <div class="stat-number">30<em>s</em></div>
            <div class="stat-label">To log a block</div>
          </div>
        </div>
      </div>
      <div class="brand-footer">© 2026 TimeLog. All rights reserved.</div>
    </div>

    <div class="form-panel">
      <div class="form-box">
        <h2 class="form-title">Create your account</h2>
        <p class="form-sub">Free forever. No credit card needed.</p>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-banner"><span>⚠</span> <%= error %></div>
        <% } %>

        <form method="POST" action="/auth/register" autocomplete="on">
          <div class="field">
            <label class="field-label" for="name">Full name</label>
            <input class="input" type="text" id="name" name="name"
              placeholder="Jane Smith" required autocomplete="name">
          </div>
          <div class="field">
            <label class="field-label" for="email">Email address</label>
            <input class="input" type="email" id="email" name="email"
              placeholder="you@example.com" required autocomplete="email">
          </div>
          <div class="field">
            <label class="field-label" for="password">Password</label>
            <input class="input" type="password" id="password" name="password"
              placeholder="Min. 8 characters" required autocomplete="new-password" minlength="8">
            <p class="field-hint">At least 8 characters. We'll never share your password.</p>
          </div>
          <button type="submit" class="btn">Create free account</button>
          <p class="terms">By creating an account you agree to our Terms of Service and Privacy Policy.</p>
        </form>

        <p class="form-footer">Already have an account? <a href="/login">Sign in →</a></p>
      </div>
    </div>

  </div>
</body>
</html>
