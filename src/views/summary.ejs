<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Summary — TimeLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>

<div class="app">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-top">
      <a href="/dashboard" class="logo">
        <div class="logo-mark">T</div>
        Time<em>Log</em>
      </a>
    </div>

    <div class="sidebar-body">
      <a href="/dashboard" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="3" width="6" height="6" rx="1.5"/>
          <rect x="11" y="3" width="6" height="6" rx="1.5"/>
          <rect x="3" y="11" width="6" height="6" rx="1.5"/>
          <rect x="11" y="11" width="6" height="6" rx="1.5"/>
        </svg>
        Dashboard
      </a>
      <a href="/summary" class="nav-item active">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 14l4-4 4 3 4-6"/>
          <path d="M3 17h14" stroke-linecap="round"/>
        </svg>
        Summary
      </a>
    </div>

    <div class="sidebar-footer">
      <div class="user-row">
        <div class="user-avatar" id="userAvatar">J</div>
        <div class="user-info">
          <div class="user-name" id="userName"><%= typeof user !== 'undefined' ? user.name : 'User' %></div>
          <div class="user-role">Free plan</div>
        </div>
        <form method="POST" action="/auth/logout">
          <button type="submit" class="btn-signout" title="Sign out">↪</button>
        </form>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <div class="summary-main">
    <div class="topbar topbar--sticky">
      <span class="topbar-title">Summary</span>
      <div class="period-tabs" id="periodTabs">
        <button class="period-tab active" onclick="setPeriod('week', this)">This week</button>
        <button class="period-tab" onclick="setPeriod('month', this)">This month</button>
        <button class="period-tab" onclick="setPeriod('year', this)">This year</button>
        <button class="period-tab" onclick="setPeriod('custom', this)">Custom</button>
      </div>
    </div>

    <div class="page">

      <div class="custom-row" id="customRow">
        <span class="custom-label">From</span>
        <input class="custom-input" type="date" id="customStart">
        <span class="custom-label">To</span>
        <input class="custom-input" type="date" id="customEnd">
        <button class="btn-apply" onclick="loadSummary()">Apply</button>
      </div>

      <div class="stats">
        <div class="stat-card">
          <div class="stat-label">Total hours</div>
          <div class="stat-value"><span id="statHours">—</span><span class="stat-unit">h</span></div>
          <div class="stat-sub" id="statHoursSub">Loading…</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Entries logged</div>
          <div class="stat-value"><span id="statEntries">—</span></div>
          <div class="stat-sub" id="statEntriesSub">Loading…</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Top tag</div>
          <div class="stat-value" style="font-size:20px;letter-spacing:-0.3px" id="statTopTag">—</div>
          <div class="stat-sub" id="statTopSub">Loading…</div>
        </div>
      </div>

      <div class="section-header">
        <h2 class="section-title">Breakdown by tag</h2>
        <span class="section-meta" id="breakdownMeta"></span>
      </div>

      <div class="breakdown" id="breakdown">
        <div class="empty">
          <div class="empty-icon">⏱</div>
          <div class="empty-title">No entries yet</div>
          <div class="empty-sub"><a href="/dashboard">Log some time</a> to see your breakdown.</div>
        </div>
      </div>

    </div>
  </div>

</div>

<script src="/js/summary.js"></script>
</body>
</html>
