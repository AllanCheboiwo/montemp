<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in — TimeLog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
</head>
<body>
  <div class="shell">

    <div class="brand">
      <div class="brand-grid"></div>
      <div class="brand-logo">Time<em>Log</em></div>
      <div class="brand-body">
        <div class="brand-eyebrow">Time tracking</div>
        <h1 class="brand-headline">
          Track every hour.<br>
          <span>Understand every day.</span>
        </h1>
        <p class="brand-sub">
          Time tracker that shows you where your time actually goes, and what it's worth.
        </p>
        <div class="brand-features">
          <div class="brand-feature">
            <div class="feature-dot">◈</div>
            <span class="feature-text">Log time blocks on a visual calendar</span>
          </div>
          <div class="brand-feature">
            <div class="feature-dot">◉</div>
            <span class="feature-text">Tag and color-code by project or focus area</span>
          </div>
          <div class="brand-feature">
            <div class="feature-dot">◎</div>
            <span class="feature-text">Get instant summaries by tag, week, or month</span>
          </div>
        </div>
      </div>
      <div class="brand-footer">© 2026 TimeLog. All rights reserved.</div>
    </div>

    <div class="form-panel">
      <div class="form-box">
        <h2 class="form-title">Welcome back</h2>
        <p class="form-sub">Sign in to your TimeLog account</p>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-banner"><span>⚠</span> <%= error %></div>
        <% } %>

        <form method="POST" action="/auth/login" autocomplete="on">
          <div class="field">
            <label class="field-label" for="email">Email address</label>
            <input class="input" type="email" id="email" name="email"
              placeholder="you@example.com" required autocomplete="email">
          </div>
          <div class="field">
            <label class="field-label" for="password">Password</label>
            <input class="input" type="password" id="password" name="password"
              placeholder="••••••••" required autocomplete="current-password">
          </div>
          <button type="submit" class="btn">Sign in</button>
        </form>

        <p class="form-footer">Don't have an account? <a href="/signup">Create one →</a></p>
      </div>
    </div>

  </div>
</body>
</html>
