# Dependencies
node_modules/
frontend/node_modules/

# Environment variables
.env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory (if you add tests later)
coverage/

# Next.js (frontend)
frontend/.next/
frontend/out/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Optional: ignore local dev files
test.js
.claude/

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/bootstrap.zip
infra/terraform.tfvars
infra/terraform.tfstate
infra/terraform.tfstate.backup

# Markdown (except README)
*.md
!README.md
